# ========== MASTHEAD ==========

<urn:news:masthead> a antenna:Object ;
    antenna:x "0.0"^^xsd:double ;
    antenna:y "-170.0"^^xsd:double ;
    antenna:worldWidth "430.0"^^xsd:double ;
    antenna:worldHeight "50.0"^^xsd:double ;
    antenna:lod [
        antenna:below "100.0"^^xsd:double ;
        antenna:widget "Text{value=FRACTAL STATION,fontSize=10,color=#F0F0F4,style=bold,fontFamily=monospace}"
    ] ;
    antenna:lod [
        antenna:below "99999.0"^^xsd:double ;
        antenna:widget "Container{color=#1E1E30,padding=10}[Column[Row[Text{value=FRACTAL STATION,fontSize=20,color=#F0F0F4,style=bold,fontFamily=monospace},Text{value=  \u2605  \u2605  \u2605,fontSize=14,color=#7799CC}],Row[Text{value=THE SPATIAL INTERFACE DAILY,fontSize=9,color=#7799CC,fontFamily=monospace},Text{value=  --  VOL.I  NO.1  --  2026,fontSize=9,color=#7799CC,fontFamily=monospace}]]]"
    ] .

