@prefix design: <http://resonator.network/v2/design#> .
@prefix sp:     <http://spinrdf.org/sp#> .
@prefix rdf:    <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:   <http://www.w3.org/2000/01/rdf-schema#> .

# =============================================================================
# Theme resolver — three SPIN-encoded CONSTRUCT queries that, given an active
# design:Theme in the store, emit a flat resolved theme graph.
#
# Active-theme selection (Decision VV, WW) happens in Rust, NOT here:
# `theme::resolve_active_theme` resolves the active theme IRI
#   1. `?_ radio:hasTheme ?t` (default graph) wins, else
#   2. `?t a design:Theme ; design:active true` (theme graph) fallback.
#
# THE EXTENDS CHAIN IS PRECOMPUTED IN RUST.  resolve_active_theme walks the
# single-inheritance `design:extends` chain from the active theme once (a few
# one-hop SELECTs, ~1ms) and injects it as a ground table via two placeholders:
#   @@ACTIVE@@  -> the active theme IRI in `<iri>` form
#   @@CHAIN@@   -> the ordered ancestor table `(<active> 0) (<parent> 1) …`
#                  most-derived first; the integer is the derivation depth.
# Both queries are INVALID SPARQL until those placeholders are substituted, so a
# missed substitution fails loudly at parse time rather than silently resolving
# nothing.
#
# WHY (perf): the previous version expressed the walk as `?activeTheme
# design:extends* ?ancestor` plus a `FILTER NOT EXISTS { … design:extends* …
# design:extends+ … }` override check. Oxigraph re-evaluates the two property
# paths *inside that NOT EXISTS for every candidate solution* and never hoists
# them, so resolution was O(solutions × path-walk): ~17s in a debug build
# (12s of it in the has-token query alone — measured: deleting the NOT EXISTS
# dropped that query from ~12000ms to ~2ms). Pinning the chain to a ground
# VALUES table removes every property path; the override check becomes a plain
# depth comparison over a ~1-3 row table. Resolution drops to well under a
# second in debug (tens of ms in release) with byte-identical output. The cost
# is no longer dominated by the build profile — it was an algorithmic property-
# path blow-up, not "debug is slow".
#
# Last-wins precedence: the most-derived ancestor (smallest depth) that binds a
# role / declares a hasToken with a given name / sets a strokeWidth wins. With
# the depth table this is `FILTER NOT EXISTS { … a row with a smaller depth that
# binds the same thing … }`.
#
# Token properties are still emitted with the PREDICATE pinned to a ground
# VALUES list (`VALUES ?tProp { design:hex … } ?token ?tProp ?tVal`), never the
# catch-all `?token ?tProp ?tVal`. A *variable* predicate — even one constrained
# by a join — defeats Oxigraph's GRAPH scoping: even inside
# `GRAPH <urn:design:theme> { … }` it scans the default graph (Swarm). Ground
# VALUES keeps the lookup indexed and theme-graph-local.
#
# Graph scoping: all theme-definition data (`a design:Theme`, design:extends,
# design:bindsRole, design:hasToken, token properties, design:strokeWidth) lives
# in the named graph <urn:design:theme>; the walk patterns are wrapped in
# `GRAPH <urn:design:theme> { … }`. The `radio:hasTheme` selector (default
# graph) is read by the Rust runner, not here.
#
# Vocabulary:   ../../arch/ontology/design.ttl
# Decision:     H2 — resolution logic lives as RDF data (these queries). The
#               extends-chain enumeration is the one part lifted into Rust,
#               because single inheritance makes it a trivial linear walk and
#               keeping it in SPARQL cost ~30x (see WHY above).
#
# Output shape (consumed by Station's ThemeStore):
#
#   ?activeTheme  a design:ResolvedTheme .
#   ?role         design:resolvesTo ?token .          # role layer
#   ?token        design:hex / design:family / ...   # token properties
#   ?activeTheme  design:hasToken ?bareToken .       # flat tokens (radii, spacing, icons)
#   ?bareToken    design:name / design:px / design:svgPath / ...
#   ?activeTheme  design:strokeWidth ?n .
# =============================================================================

<urn:resolver:theme> a design:ThemeResolver ;
    rdfs:label "Voidline theme resolver" ;
    rdfs:comment "Three SPARQL CONSTRUCT queries that resolve an extends-chain (precomputed as a ground depth table) into a flat theme graph." ;
    design:resolves <urn:resolver:theme/role-bindings> ,
                    <urn:resolver:theme/has-token> ,
                    <urn:resolver:theme/stroke-width> .

# -----------------------------------------------------------------------------
# Query 1 — role bindings + token properties for bound tokens
#
# For each (role, token) binding on any ancestor in the @@CHAIN@@ table, emit
# ?role design:resolvesTo ?token unless a strictly more-derived ancestor (a row
# with a smaller depth) also binds the same role. Emits the bound token's own
# properties so consumers can read hex / family / size without a second query.
# -----------------------------------------------------------------------------

<urn:resolver:theme/role-bindings> a sp:Construct ;
    rdfs:label "Resolve role bindings" ;
    sp:text """
PREFIX design: <http://resonator.network/v2/design#>
CONSTRUCT {
  @@ACTIVE@@ a design:ResolvedTheme .
  ?role design:resolvesTo ?token .
  ?token ?tProp ?tVal .
}
WHERE {
  GRAPH <urn:design:theme> {
    VALUES (?ancestor ?depth) { @@CHAIN@@ }
    ?ancestor design:bindsRole ?binding .
    ?binding design:role ?role ;
             design:to ?token .
    FILTER NOT EXISTS {
      VALUES (?md ?mdDepth) { @@CHAIN@@ }
      FILTER(?mdDepth < ?depth)
      ?md design:bindsRole ?override .
      ?override design:role ?role .
    }
    # Emit the bound token's own properties. ?tProp MUST be ground (this VALUES
    # list, NOT a `?tProp a rdf:Property` pattern): a variable predicate makes
    # Oxigraph scan the default graph (Swarm), so resolution would scale with
    # store size. With ?tProp pinned this is an indexed, theme-graph-local
    # lookup. ⚠️ Keep this list in sync with the token-value properties in
    # design.ttl.
    OPTIONAL {
      VALUES ?tProp {
        design:hex design:alpha design:name design:svgPath design:viewBox
        design:weight design:size design:lineHeight design:fill design:family
        design:px design:tracking design:case design:italic
      }
      ?token ?tProp ?tVal .
    }
  }
}
""" .

# -----------------------------------------------------------------------------
# Query 2 — flat tokens (radii, spacing, icons)
#
# Declared via ?ancestor design:hasToken ?t and identified by design:name (e.g.
# "r2", "s4", "lock"). For each name, the most-derived ancestor's token wins.
# -----------------------------------------------------------------------------

<urn:resolver:theme/has-token> a sp:Construct ;
    rdfs:label "Resolve flat tokens" ;
    sp:text """
PREFIX design: <http://resonator.network/v2/design#>
CONSTRUCT {
  @@ACTIVE@@ design:hasToken ?token .
  ?token ?tProp ?tVal .
}
WHERE {
  GRAPH <urn:design:theme> {
    VALUES (?ancestor ?depth) { @@CHAIN@@ }
    ?ancestor design:hasToken ?token .
    ?token design:name ?name .
    FILTER NOT EXISTS {
      VALUES (?md ?mdDepth) { @@CHAIN@@ }
      FILTER(?mdDepth < ?depth)
      ?md design:hasToken ?override .
      ?override design:name ?name .
    }
    # Ground-predicate token-property emission (see Query 1's note).
    VALUES ?tProp {
      design:hex design:alpha design:name design:svgPath design:viewBox
      design:weight design:size design:lineHeight design:fill design:family
      design:px design:tracking design:case design:italic
    }
    ?token ?tProp ?tVal .
  }
}
""" .

# -----------------------------------------------------------------------------
# Query 3 — strokeWidth (single-valued theme property)
# -----------------------------------------------------------------------------

<urn:resolver:theme/stroke-width> a sp:Construct ;
    rdfs:label "Resolve stroke width" ;
    sp:text """
PREFIX design: <http://resonator.network/v2/design#>
CONSTRUCT {
  @@ACTIVE@@ design:strokeWidth ?sw .
}
WHERE {
  GRAPH <urn:design:theme> {
    VALUES (?ancestor ?depth) { @@CHAIN@@ }
    ?ancestor design:strokeWidth ?sw .
    FILTER NOT EXISTS {
      VALUES (?md ?mdDepth) { @@CHAIN@@ }
      FILTER(?mdDepth < ?depth)
      ?md design:strokeWidth ?override .
    }
  }
}
""" .
