@prefix design: <http://resonator.network/v2/design#> .
@prefix sp:     <http://spinrdf.org/sp#> .
@prefix rdf:    <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:   <http://www.w3.org/2000/01/rdf-schema#> .

# =============================================================================
# Theme resolver — three SPIN-encoded CONSTRUCT queries that, given an active
# design:Theme in the store, emit a flat resolved theme graph.
#
# Active-theme selection (Decision VV, WW) happens in Rust, NOT here:
# `theme::resolve_active_theme` resolves the active theme IRI
#   1. `?_ radio:hasTheme ?t` (default graph) wins, else
#   2. `?t a design:Theme ; design:active true` (theme graph) fallback,
# then injects `VALUES ?activeTheme { <iri> }` at the top of each WHERE before
# running it, so the walk runs with the theme pinned to a constant rather than
# joined from a cross-graph `radio:hasTheme` binding.
#
# Token properties are emitted with the PREDICATE pinned to a ground VALUES
# list (`VALUES ?tProp { design:hex … } ?token ?tProp ?tVal`), never the
# catch-all `?token ?tProp ?tVal`. A *variable* predicate — even one
# constrained by a join like `?tProp a rdf:Property` — defeats Oxigraph's GRAPH
# scoping: even inside `GRAPH <urn:design:theme> { … }` it scans the default
# graph (Swarm), so resolution scaled with store size (~8s on a hydrated
# messenger2 store) and, as the persistent store grew, eventually never
# returned. Ground VALUES keeps the lookup indexed and theme-graph-local, with
# cost independent of Swarm size. (Measured: identical resolve time on a clean
# store and one with 8k extra default-graph triples.)
#
# Graph scoping: all theme-definition data (`a design:Theme`, design:extends,
# design:bindsRole, design:hasToken, token properties, design:strokeWidth)
# lives in the named graph <urn:design:theme>; only the `radio:hasTheme`
# selector reads the default graph (where the radio seed puts it). The walk
# patterns are wrapped in `GRAPH <urn:design:theme> { … }` so resolution cost
# is O(theme-graph), independent of how much radio/swarm data has accumulated
# in the default graph. Without this, a populated store (e.g. messenger2 with a
# hydrated Swarm) degraded the resolver to a whole-store scan that pinned the
# embedded worker at ~100% CPU and never returned — Station's B2 boot gate then
# hung black forever (theme bundle never emitted).
#
# Last-wins precedence over the design:extends inheritance chain. Most-derived
# theme that binds a role / declares a hasToken with a given name / sets a
# strokeWidth wins.
#
# Vocabulary:   ../../arch/ontology/design.ttl
# Decision:     H2 — resolution lives as RDF data (these queries), not Rust.
#
# Output shape (consumed by Station's ThemeStore):
#
#   ?activeTheme  a design:ResolvedTheme .
#   ?role         design:resolvesTo ?token .          # role layer
#   ?token        design:hex / design:family / ...   # token properties
#   ?activeTheme  design:hasToken ?bareToken .       # flat tokens (radii, spacing, icons)
#   ?bareToken    design:name / design:px / design:svgPath / ...
#   ?activeTheme  design:strokeWidth ?n .
# =============================================================================

<urn:resolver:theme> a design:ThemeResolver ;
    rdfs:label "Voidline theme resolver" ;
    rdfs:comment "Three SPARQL CONSTRUCT queries that resolve an extends-chain into a flat theme graph." ;
    design:resolves <urn:resolver:theme/role-bindings> ,
                    <urn:resolver:theme/has-token> ,
                    <urn:resolver:theme/stroke-width> .

# -----------------------------------------------------------------------------
# Query 1 — role bindings + token properties for bound tokens
#
# Walks the extends* chain from ?activeTheme. For each (role, token) binding
# on any ancestor, emits ?role design:resolvesTo ?token unless a strictly more
# derived ancestor also binds the same role. Emits the bound token's own
# properties so consumers can read hex / family / size / etc. without a second
# round-trip.
# -----------------------------------------------------------------------------

<urn:resolver:theme/role-bindings> a sp:Construct ;
    rdfs:label "Resolve role bindings" ;
    sp:text """
PREFIX design: <http://resonator.network/v2/design#>
PREFIX radio:  <http://resonator.network/v2/radio#>
CONSTRUCT {
  ?activeTheme a design:ResolvedTheme .
  ?role design:resolvesTo ?token .
  ?token ?tProp ?tVal .
}
WHERE {
  # ?activeTheme is bound to a constant by the Rust caller
  # (theme::resolve_active_theme injects `VALUES ?activeTheme { <iri> }`).
  GRAPH <urn:design:theme> {
    ?activeTheme design:extends* ?ancestor .
    ?ancestor design:bindsRole ?binding .
    ?binding design:role ?role ;
             design:to ?token .
    FILTER NOT EXISTS {
      ?activeTheme design:extends* ?moreDerived .
      ?moreDerived design:extends+ ?ancestor .
      ?moreDerived design:bindsRole ?override .
      ?override design:role ?role .
    }
    # Emit the bound token's own properties. ?tProp MUST be ground (a VALUES
    # list, NOT a `?tProp a rdf:Property` pattern): a variable predicate —
    # even one constrained by a join — makes Oxigraph scan the default graph
    # (Swarm), so resolution scaled with store size and eventually hung. With
    # ?tProp pinned to the token-value predicates, this is an indexed,
    # theme-graph-local lookup whose cost is independent of Swarm size.
    # ⚠️ Keep this list in sync with the token-value properties in design.ttl.
    OPTIONAL {
      VALUES ?tProp {
        design:hex design:alpha design:name design:svgPath design:viewBox
        design:weight design:size design:lineHeight design:fill design:family
        design:px design:tracking design:case design:italic
      }
      ?token ?tProp ?tVal .
    }
  }
}
""" .

# -----------------------------------------------------------------------------
# Query 2 — flat tokens (radii, spacing, icons)
#
# These are declared via ?theme design:hasToken ?t and identified by
# design:name (e.g. "r2", "s4", "lock"). For each name, the most-derived
# ancestor's token wins.
# -----------------------------------------------------------------------------

<urn:resolver:theme/has-token> a sp:Construct ;
    rdfs:label "Resolve flat tokens" ;
    sp:text """
PREFIX design: <http://resonator.network/v2/design#>
PREFIX radio:  <http://resonator.network/v2/radio#>
CONSTRUCT {
  ?activeTheme design:hasToken ?token .
  ?token ?tProp ?tVal .
}
WHERE {
  # ?activeTheme bound to a constant by the Rust caller (see Query 1).
  GRAPH <urn:design:theme> {
    ?activeTheme design:extends* ?ancestor .
    ?ancestor design:hasToken ?token .
    ?token design:name ?name .
    FILTER NOT EXISTS {
      ?activeTheme design:extends* ?moreDerived .
      ?moreDerived design:extends+ ?ancestor .
      ?moreDerived design:hasToken ?override .
      ?override design:name ?name .
    }
    # Ground-predicate token-property emission (see Query 1's note).
    VALUES ?tProp {
      design:hex design:alpha design:name design:svgPath design:viewBox
      design:weight design:size design:lineHeight design:fill design:family
      design:px design:tracking design:case design:italic
    }
    ?token ?tProp ?tVal .
  }
}
""" .

# -----------------------------------------------------------------------------
# Query 3 — strokeWidth (single-valued theme property)
# -----------------------------------------------------------------------------

<urn:resolver:theme/stroke-width> a sp:Construct ;
    rdfs:label "Resolve stroke width" ;
    sp:text """
PREFIX design: <http://resonator.network/v2/design#>
PREFIX radio:  <http://resonator.network/v2/radio#>
CONSTRUCT {
  ?activeTheme design:strokeWidth ?sw .
}
WHERE {
  # ?activeTheme bound to a constant by the Rust caller (see Query 1).
  GRAPH <urn:design:theme> {
    ?activeTheme design:extends* ?ancestor .
    ?ancestor design:strokeWidth ?sw .
    FILTER NOT EXISTS {
      ?activeTheme design:extends* ?moreDerived .
      ?moreDerived design:extends+ ?ancestor .
      ?moreDerived design:strokeWidth ?override .
    }
  }
}
""" .
